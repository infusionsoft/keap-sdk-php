{
    "name": "keap/keap-sdk",
    "version": "2.0.10",
    "description": "Keap Public API Documentation",
    "keywords": [
        "openapitools",
        "openapi-generator",
        "openapi",
        "php",
        "sdk",
        "rest",
        "api"
    ],
    "homepage": "https://github.com/infusionsoft/keap-sdk",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Keap Engineering",
            "homepage": "https://developer.keap.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5.22 || ^13.1.6",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "Keap\\Core\\V2\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Keap\\Core\\V2\\Test\\": "test/"
        }
    },
    "config": {
        "platform": {
            "php": "8.3"
        }
    }
}
